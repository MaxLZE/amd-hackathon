{
  "version": 2,
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api",
      "destination": "/api/index"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/app.js",
      "destination": "/web/app.js"
    },
    {
      "source": "/styles.css",
      "destination": "/web/styles.css"
    },
    {
      "source": "/(.*)",
      "destination": "/web/index.html"
    }
  ]
}
