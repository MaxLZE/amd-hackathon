FIREWORKS_API_KEY=replace-with-local-key
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# PLACEHOLDER model IDs — replace with the real ALLOWED_MODELS list published
# on launch day, and mirror it in DEFAULT_TIER_PREFERENCES (router_core.py).
